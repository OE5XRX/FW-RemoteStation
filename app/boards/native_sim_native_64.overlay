 *
 * Native Simulator Device Tree Overlay
 * Configures GPIO emulators for SA818 driver testing. The SA818 driver only
 * does AT/UART + control GPIOs; the hardware-timed audio path (analog-audio-in /
 * analog-audio-out) is STM32-only and is not instantiated on native_sim.
 */

/ {
  aliases {
    config-eeprom0 = &eeprom0;
    sa818 = &sa818;
  };

  /* Virtueller GPIO-Controller für SA818 */
  gpio_sa818: gpio_sa818 {
    compatible = "zephyr,gpio-emul";
    status = "okay";
    #gpio-cells = <2>;
    gpio-controller;
  };

  /* SA818 Device */
  sa818: sa818 {
    compatible = "sa,sa818";
    status = "okay";

    band = "vhf";
    uart = <&uart1>;

    h-l-power-gpios   = <&gpio_sa818 0 GPIO_ACTIVE_HIGH>;
    nptt-gpios        = <&gpio_sa818 1 GPIO_ACTIVE_LOW>;
    npower-down-gpios = <&gpio_sa818 2 GPIO_ACTIVE_LOW>;
    nsquelch-gpios    = <&gpio_sa818 3 GPIO_ACTIVE_LOW>;

    tx-enable-delay-ms = <20>;
    rx-settle-time-ms  = <50>;
  };
};

&uart1 {
  status = "okay";
  current-speed = <9600>;
};
