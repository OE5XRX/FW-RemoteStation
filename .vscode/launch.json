// Configure debug launch settings
// Feel free to copy these and modify them for your debugger and MCU
{
  "version": "0.2.0",
  "projectName": "STM32-Test",
  "configurations": [
    {
      "name": "Debug Unittest",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceRoot}/build-ut/test/test-OE5XRX",
      "cwd": "${workspaceRoot}",
      //"preLaunchTask": "Build Unittest"
    },
    {
      "name": "STlink launch",
      "cwd": "${workspaceRoot}",
      "executable": "${workspaceRoot}/build/OE5XRX.elf",
      "request": "launch",
      "type": "cortex-debug",
      "servertype": "stutil",
      "device": "STM32F302CBT",
      "interface": "swd",
      "runToEntryPoint": "main",
      "preLaunchTask": "Build all", // configured in tasks.json
      // "preLaunchCommands": ["Build all"], // you can execute command instead of task
      "svdFile": "", // Include svd to watch device peripherals
      "swoConfig": {} // currently (v1.7.0) not supported
    },
    {
      "name": "STlink attach",
      "cwd": "${workspaceRoot}",
      "executable": "${workspaceRoot}/build/OE5XRX.elf",
      "request": "attach",
      "type": "cortex-debug",
      "servertype": "stutil",
      "device": "STM32F302CBT",
      "interface": "swd",
      "runToEntryPoint": "main",
      "preLaunchTask": "Build all", // configured in tasks.json
      // "preLaunchCommands": ["Build all"], // you can execute command instead of task
      "svdFile": "", // Include svd to watch device peripherals
      "swoConfig": {} // currently (v1.7.0) not supported
    },
  ]
}
