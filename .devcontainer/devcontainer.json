{
  "name": "Zephyr Development Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/user/workspace,type=bind",
  "workspaceFolder": "/home/user/workspace",
  "postStartCommand": "west init -l . && west update && mkdir /home/user/.oh-my-zsh/functions && west completion zsh > /home/user/.oh-my-zsh/functions/_west",
  "remoteUser": "user",
  "runArgs": [
    "-v",
    "/dev:/dev", //
    "--privileged" // allows access to tty* devices
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "xaver.clang-format",
        "ms-vscode.cpptools-extension-pack",
        "nordic-semiconductor.nrf-connect-extension-pack",
        "ms-python.python",
        "github.copilot",
        "github.copilot-chat"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  }
}
