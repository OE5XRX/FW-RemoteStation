# FM Board Hardware Configuration (fm_board_defconfig)
# Board-specific hardware enablement for STM32F302VC-based FM transceiver.
# This file contains only hardware-specific configurations that are tied to
# the physical board design. Software-level configs belong in app/prj.conf.

# =============================================================================
# ARM Cortex-M4 Core Features
# =============================================================================
CONFIG_ARM_MPU=y
CONFIG_HW_STACK_PROTECTION=y

# =============================================================================
# Peripheral Hardware Drivers
# =============================================================================

# GPIO - Required for SA818 control signals (power, PTT, squelch)
CONFIG_GPIO=y

# Voltage Regulators - 3.3V power control
CONFIG_REGULATOR=y

# EEPROM - AT24C256 for persistent storage
CONFIG_EEPROM=y

# ADC - Analog-to-Digital Converter for audio input
CONFIG_ADC=y

# DAC - Digital-to-Analog Converter for audio output  
CONFIG_DAC=y

# =============================================================================
# USB Hardware Stack
# =============================================================================

# USB Device Controller (STM32 USB peripheral)
CONFIG_USB_DEVICE_STACK_NEXT=y

# USB CDC ACM - Virtual serial port for console
CONFIG_USBD_CDC_ACM_CLASS=y
CONFIG_CDC_ACM_SERIAL_INITIALIZE_AT_BOOT=n

# USB Device Class: UAC2 (USB Audio Class 2)
CONFIG_USBD_AUDIO2_CLASS=y

# USB Buffer Configuration
CONFIG_UDC_BUF_POOL_SIZE=4096

# =============================================================================
# USB Device Stack - Software Features
# =============================================================================

# USB debugging and testing
CONFIG_USBD_SHELL=y            # USB device shell commands
CONFIG_USBD_LOOPBACK_CLASS=y   # Loopback endpoint for testing

# USB subsystem logging (reduce verbosity)
CONFIG_USBD_LOG_LEVEL_ERR=y
CONFIG_UDC_DRIVER_LOG_LEVEL_ERR=y
CONFIG_USBD_CDC_ACM_LOG_LEVEL_OFF=y
