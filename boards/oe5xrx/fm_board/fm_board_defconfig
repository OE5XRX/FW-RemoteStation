# Enable MPU
CONFIG_ARM_MPU=y

# Enable HW stack protection
CONFIG_HW_STACK_PROTECTION=y

# enable uart driver
CONFIG_SERIAL=y

# enable console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# enable GPIO
CONFIG_GPIO=y

# enable DMA (used by the analog-audio-in/out LL+DMA capture/playback drivers)
CONFIG_DMA=y

# enable hardware-timed analog audio capture (TIM+ADC+DMA)
CONFIG_ANALOG_AUDIO_IN=y

# enable hardware-timed analog audio playback (TIM+DAC+DMA)
CONFIG_ANALOG_AUDIO_OUT=y

# enable regulators
CONFIG_REGULATOR=y

# USB Configuration
CONFIG_USB_DEVICE_STACK_NEXT=y
# The STM32U575 OTG is full-speed only (DT maximum-speed = "full-speed"). The
# STM32 UDC Kconfig selects UDC_DRIVER_HAS_HIGH_SPEED_SUPPORT, which otherwise
# defaults the device stack to High-Speed. Force full-speed to match the hardware
# and drop the unused high-speed descriptor/config support. Disabling the
# high-speed chirp is also what unlocks USBD_MAX_SPEED_FULL (its dependency is
# !UDC_DRIVER_HIGH_SPEED_SUPPORT_ENABLED).
CONFIG_UDC_DRIVER_HIGH_SPEED_SUPPORT_ENABLED=n
CONFIG_USBD_MAX_SPEED_FULL=y
CONFIG_SAMPLE_USBD_VID=0x2FE3
CONFIG_SAMPLE_USBD_PID=0x0012
CONFIG_SAMPLE_USBD_PRODUCT="FM Transceiver Board"
CONFIG_SAMPLE_USBD_MANUFACTURER="OE5XRX"
CONFIG_SAMPLE_USBD_SELF_POWERED=n
CONFIG_SAMPLE_USBD_MAX_POWER=250

# USB CDC ACM - Shell/Console
CONFIG_STDOUT_CONSOLE=y
CONFIG_UART_LINE_CTRL=y
CONFIG_USBD_CDC_ACM_CLASS=y
CONFIG_CDC_ACM_SERIAL_INITIALIZE_AT_BOOT=n

# USB Audio Class 2 - SA818 Audio Streaming
CONFIG_USBD_AUDIO2_CLASS=y

# USB DFU - Firmware Update
CONFIG_USBD_DFU=y

# Logging
CONFIG_LOG=y
CONFIG_USBD_LOG_LEVEL_WRN=y
CONFIG_UDC_DRIVER_LOG_LEVEL_WRN=y
CONFIG_USBD_CDC_ACM_LOG_LEVEL_OFF=y
